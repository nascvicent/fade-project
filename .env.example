# ===========================================
# Lesson Plan Manager — Environment Variables
# ===========================================

# ── Database ──
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lesson_plans?schema=public"

# ── Backend ──
PORT=3333
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── AI / LLM ──
# Escolha o provider: "openai" | "anthropic" | "google"
AI_PROVIDER=google
AI_API_KEY=your-api-key-here
AI_MODEL=gemini-2.0-flash
# AI_MODEL=gpt-4o-mini          # se usar OpenAI
# AI_MODEL=claude-sonnet-4-20250514  # se usar Anthropic

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:3333
